# World Forge production environment template.
# Copy values into your deployment platform or secret manager.
# Do not commit real production secrets.

# Runtime profile and ports.
SPRING_PROFILES_ACTIVE=production
SERVER_PORT=8080
VITE_WEB_PORT=8080

# Frontend API origin.
# Leave empty only for same-origin deployments where /api is routed to Spring Boot.
# For split frontend/API deployments, set this at frontend build time, for example:
# VITE_API_BASE_URL=https://api.worldforge.example.com
VITE_API_BASE_URL=

# PostgreSQL source of truth.
# Replace host, database, user, and password with managed PostgreSQL or production database values.
WORLD_FORGE_DB_URL=jdbc:postgresql://replace-with-postgres-host:5432/world_forge
WORLD_FORGE_DB_USER=replace-with-postgres-user
WORLD_FORGE_DB_PASSWORD=replace-with-postgres-password-from-secret-manager
WORLD_FORGE_JPA_DDL_AUTO=validate
WORLD_FORGE_FLYWAY_ENABLED=true

# Elasticsearch public-map projection.
# Keep Elasticsearch private to the API network; browsers must not call it directly.
WORLD_FORGE_ELASTICSEARCH_URL=https://replace-with-elasticsearch-host:9200
WORLD_FORGE_SEARCH_ENABLED=true
WORLD_FORGE_SEARCH_INDEX_NAME=world_forge_maps

# JWT auth.
# Required: replace with a long random secret, at least 32 bytes of entropy.
# Keep the same value across rolling API instances.
WORLD_FORGE_JWT_SECRET=replace-with-random-base64-secret-from-secret-manager
WORLD_FORGE_JWT_ISSUER=world-forge-api
WORLD_FORGE_JWT_TTL_SECONDS=3600

# CORS.
# Same-origin deployments may keep this empty.
# Split frontend/API deployments must set the exact frontend origin; do not use wildcard origins.
WORLD_FORGE_CORS_ALLOWED_ORIGINS=https://worldforge.example.com

# Admin reindex endpoint.
# Keep disabled by default. Enable only during a protected maintenance window.
WORLD_FORGE_ADMIN_ENABLED=false
WORLD_FORGE_ADMIN_TOKEN=replace-with-maintenance-token-from-secret-manager

# WASM artifact path.
# No env var is read by the current frontend for this path.
# Production static hosting must serve:
# /wasm/world_forge_engine.js
# /wasm/world_forge_engine.wasm
