# World Forge local development environment.
# Copy to .env.local or export the values in your shell.
# These values are safe local placeholders only. Do not reuse them in production.

# Runtime profile and ports.
# SPRING_PROFILES_ACTIVE is available for future profile-specific config; the current API mostly uses explicit WORLD_FORGE_* values.
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
VITE_WEB_PORT=5173

# Frontend API origin.
# Leave empty for Vite dev proxy and same-origin /api calls.
# Set to http://localhost:8080 only if the browser should call the API origin directly; then keep CORS allowed origins below.
# The local full-stack compose override builds the web image with http://localhost:${SERVER_PORT:-8080}
# even when this value is empty, because browser traffic must reach the host-published API.
VITE_API_BASE_URL=

# PostgreSQL source of truth.
# Use localhost when the Spring Boot API runs on the host.
# Use jdbc:postgresql://postgres:5432/world_forge when the API runs inside a compose network.
WORLD_FORGE_DB_URL=jdbc:postgresql://localhost:5432/world_forge
WORLD_FORGE_DB_USER=world_forge
WORLD_FORGE_DB_PASSWORD=world_forge_dev
# Local full-stack uses update so older local Docker volumes can be bootstrapped/healed.
# Production must use validate; see .env.production.example.
WORLD_FORGE_JPA_DDL_AUTO=update
WORLD_FORGE_FLYWAY_ENABLED=true

# Elasticsearch public-map projection.
# Use localhost when the API runs on the host.
# Use http://elasticsearch:9200 when the API runs inside a compose network.
WORLD_FORGE_ELASTICSEARCH_URL=http://localhost:9200
WORLD_FORGE_SEARCH_ENABLED=true
WORLD_FORGE_SEARCH_INDEX_NAME=world_forge_maps

# JWT auth.
# Local placeholder only. Production must use a long random secret from a secret manager.
WORLD_FORGE_JWT_SECRET=local-dev-change-me-32-byte-placeholder
WORLD_FORGE_JWT_ISSUER=world-forge-api-local
WORLD_FORGE_JWT_TTL_SECONDS=3600

# CORS.
# Vite dev normally proxies /api, but this allows direct browser calls from the local web origin when VITE_API_BASE_URL is set.
# Use exact origins only. Wildcard origins are rejected by the API.
WORLD_FORGE_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Admin reindex endpoint.
# Local development can enable this to run POST /api/admin/search/maps/reindex.
WORLD_FORGE_ADMIN_ENABLED=true
WORLD_FORGE_ADMIN_TOKEN=local-admin-token-change-me

# WASM artifact path.
# No env var is read by the current frontend for this path.
# Build with npm run wasm:build and serve these files at:
# /wasm/world_forge_engine.js
# /wasm/world_forge_engine.wasm
